rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ── Users ──
    // Users can read/write their own doc. Admins can read all.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ── Products ──
    // Public read. Admin-only write.
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Categories ──
    // Public read. Admin-only write.
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Orders ──
    // User can read their own orders. Admin can read/write all.
    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── Carts ──
    // Open read/write — carts are keyed by visitorId and validated server-side.
    match /carts/{cartId} {
      allow read, write: if true;
    }

    // ── Wishlists ──
    // User can only read/write their own wishlist (doc ID = userId).
    match /wishlists/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── Promotions ──
    // Public read. Admin-only write.
    match /promotions/{promoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Settings ──
    // Public read. Admin-only write.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Chatbot Knowledge Base ──
    // Admin only. Server reads via Admin SDK bypass these rules.
    match /chatbot_kb/{entryId} {
      allow read, write: if isAdmin();
    }

    // ── Chatbot Rate Limits ──
    // Deny all client access. Server manages via Admin SDK.
    match /chatbot_rate_limits/{limitId} {
      allow read, write: if false;
    }
  }
}
